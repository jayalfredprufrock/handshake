{
  "name": "@jayalfredprufrock/handshake",
  "version": "0.0.0-semantically-released",
  "description": "Describe your backend API as a contract and get a fully-typed http client without a compile step.",
  "homepage": "https://github.com/jayalfredprufrock/handshake#readme",
  "bugs": {
    "url": "https://github.com/jayalfredprufrock/handshake/issues"
  },
  "license": "MIT",
  "author": "Andrew Smiley <jayalfredprufrock@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayalfredprufrock/handshake.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./client": "./src/client/index.ts",
    "./contract": "./src/contract/index.ts",
    "./hono": "./src/adapters/hono/index.ts",
    "./nestjs": "./src/adapters/nestjs/index.ts",
    "./openapi": "./src/openapi/index.ts",
    "./server": "./src/server/index.ts",
    "./typebox": "./src/typebox/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      "./client": {
        "import": "./dist/client.mjs",
        "require": "./dist/client.cjs"
      },
      "./contract": {
        "import": "./dist/contract.mjs",
        "require": "./dist/contract.cjs"
      },
      "./hono": {
        "import": "./dist/hono.mjs",
        "require": "./dist/hono.cjs"
      },
      "./nestjs": {
        "import": "./dist/nestjs.mjs",
        "require": "./dist/nestjs.cjs"
      },
      "./openapi": {
        "import": "./dist/openapi.mjs",
        "require": "./dist/openapi.cjs"
      },
      "./server": {
        "import": "./dist/server.mjs",
        "require": "./dist/server.cjs"
      },
      "./typebox": {
        "import": "./dist/typebox.mjs",
        "require": "./dist/typebox.cjs"
      },
      "./package.json": "./package.json"
    },
    "access": "public"
  },
  "scripts": {
    "dev": "vp run -r dev",
    "prepare": "vp config"
  },
  "dependencies": {
    "openapi-types": "catalog:"
  },
  "devDependencies": {
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/testing": "catalog:",
    "@semantic-release/exec": "^7.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "conventional-changelog-conventionalcommits": "catalog:",
    "hono": "^4.12.9",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "semantic-release": "^25.0.3",
    "tslib": "catalog:",
    "typescript": "^6.0.2",
    "vite-plus": "0.2.1"
  },
  "peerDependencies": {
    "@nestjs/common": "^10 || ^11",
    "@nestjs/core": "^10 || ^11",
    "hono": "^4.12.9",
    "reflect-metadata": "^0.1.13 || ^0.2",
    "rxjs": "^7.8",
    "typebox": "^1.1.13"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "conventionalcommits"
        }
      ],
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "pnpm version ${nextRelease.version} --no-git-tag-version",
          "publishCmd": "pnpm publish --no-git-checks"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
