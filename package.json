{
  "name": "@jayalfredprufrock/handshake",
  "version": "0.0.0-semantically-released",
  "description": "Describe your backend API as a contract and get a fully-typed http client without a compile step.",
  "homepage": "https://github.com/jayalfredprufrock/handshake#readme",
  "bugs": {
    "url": "https://github.com/jayalfredprufrock/handshake/issues"
  },
  "license": "MIT",
  "author": "Andrew Smiley <jayalfredprufrock@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayalfredprufrock/handshake.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    "./client": "./src/client/index.ts",
    "./contract": "./src/contract/index.ts",
    "./hono": "./src/adapters/hono/index.ts",
    "./server": "./src/server/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./client": {
        "import": "./dist/client.mjs",
        "require": "./dist/client.cjs"
      },
      "./contract": {
        "import": "./dist/contract.mjs",
        "require": "./dist/contract.cjs"
      },
      "./hono": {
        "import": "./dist/hono.mjs",
        "require": "./dist/hono.cjs"
      },
      "./server": {
        "import": "./dist/server.mjs",
        "require": "./dist/server.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "dev": "vp run -r dev",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "hono": "^4.12.9",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.14"
  },
  "peerDependencies": {
    "hono": "^4.12.9",
    "typebox": "^1.1.13"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
